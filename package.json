{
  "name": "music-hub",
  "version": "0.1.0",
  "description": "HTTP/MCP API service for LX Music source capabilities.",
  "license": "GPL-3.0-only",
  "type": "module",
  "main": "src/index.js",
  "bin": {
    "music-hub": "src/index.js"
  },
  "scripts": {
    "start": "node src/index.js",
    "start:http": "node src/index.js http",
    "start:mcp": "node src/index.js mcp",
    "start:stdio": "node src/index.js stdio",
    "start:all": "node src/index.js all",
    "test": "node --test \"test/*.test.js\"",
    "check": "node --check src/index.js"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "keywords": [
    "lx-music",
    "music",
    "api",
    "mcp"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "iconv-lite": "^0.6.3",
    "node-id3": "^0.2.9",
    "smart-lyric": "1.0.4",
    "zod": "^4.4.3"
  }
}
